<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - Aplikasi Manajemen Keuangan</title>
  <link rel="stylesheet" href="/styles/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
  <%- include('partials/navbar', { active: 'dashboard' }) %>

  <main class="container dashboard-container">
    <div class="dashboard-header">
      <div>
        <h2 class="page-title">Halo, <span id="dashboard-user-name">Caca</span>!</h2>
        <p class="page-subtitle">Selamat datang! kelola keuangan anda dengan mudah.</p>
      </div>
      <div class="dashboard-actions">
        <a href="/transaksi" class="btn btn-primary">+ Tambah Transaksi</a>
        <a href="/laporan" class="btn btn-secondary">📊 Lihat Laporan</a>
      </div>
    </div>

    <div class="summary-cards">
      <div class="card card-income">
        <div class="card-top">
          <span class="card-icon">💰</span>
          <h3>Total Pemasukan</h3>
        </div>
        <p class="amount" id="total-income">Rp 0</p>
      </div>
      <div class="card card-expense">
        <div class="card-top">
          <span class="card-icon">💸</span>
          <h3>Total Pengeluaran</h3>
        </div>
        <p class="amount" id="total-expense">Rp 0</p>
      </div>
      <div class="card card-balance">
        <div class="card-top">
          <span class="card-icon">👛</span>
          <h3>Saldo Tersisa</h3>
        </div>
        <p class="amount" id="balance">Rp 0</p>
      </div>
    </div>

    <div class="chart-and-recent">
      <div class="chart-container">
        <div class="chart-header">
          <h3>Grafik Keuangan Bulanan</h3>
          <div class="chart-filters">
            <select aria-label="Pilih Bulan">
              <option>Bulan ini</option>
              <option>Juni</option>
              <option>Juli</option>
            </select>
            <select aria-label="Pilih Tahun">
              <option>2026</option>
              <option>2025</option>
            </select>
          </div>
        </div>
        <canvas id="chart"></canvas>
      </div>

      <div class="recent-transactions">
        <div class="table-toolbar">
          <div class="search-box">
            <span>🔍</span>
            <input type="search" placeholder="Cari transaksi..." />
          </div>
          <div class="table-filters">
            <button type="button" class="filter-pill active">Semua</button>
            <button type="button" class="filter-pill">Pemasukan</button>
            <button type="button" class="filter-pill">Pengeluaran</button>
          </div>
        </div>
        <h3>Transaksi Terbaru</h3>
        <div class="table-scroll">
          <table id="recent-table">
            <thead>
              <tr>
                <th>Tanggal</th>
                <th>Keterangan</th>
                <th>Jenis</th>
                <th>Jumlah</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="/scripts/auth.js"></script>
  <script src="/scripts/dashboard.js"></script>
</body>
</html>

